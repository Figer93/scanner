    },
    "git": {
      "command": "node",
      "args": ["mcp/git-mcp/server.js"]
    },
    "railway": {
      "command": "node",
      "args": ["mcp/railway-mcp/server.js"]
    },
    "mailgun": {
      "command": "npx",
      "args": ["-y", "@mailgun/mcp-server"],
      "env": {
        "MAILGUN_API_KEY": "",
        "MAILGUN_API_REGION": "eu"
      }
    }
  }
}