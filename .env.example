# Environment configuration for Foundly Start.
# Copy to .env and set values. All variables are optional except where noted.

# Runtime
NODE_ENV=production
PORT=3001

# Database (required). Supabase PostgreSQL connection string.
# Get from Supabase: Project Settings → Database → Connection string (URI). Use Transaction pooler (port 6543) for serverless.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# If you see "self-signed certificate in certificate chain" (e.g. behind a corporate proxy), set:
# PG_SSL_REJECT_UNAUTHORIZED=0

# Admin / API auth (optional; set if you use token-protected endpoints)
ADMIN_TOKEN=

# Serper (Google search) – required for website discovery
SERPER_API_KEY=
# Cap Google organic results per Serper request (1–100). Use 2 for testing; omit in production for full result sets.
# SERPER_NUM_RESULTS=2
# (alias) SERPER_MAX_RESULTS=2

# Companies House (optional – for live fetch of newly incorporated companies)
COMPANIES_HOUSE_API_KEY=

# Google Places (optional – for Google Maps business search by keyword + location)
GOOGLE_PLACES_API_KEY=

# Google AI Studio (optional – free lead scoring; get key at https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=

# Brevo (email sending & tracking). Get API key: Brevo → SMTP & API → API Keys.
BREVO_API_KEY=
# Required for Brevo webhooks: set the same secret in Brevo dashboard (query ?secret= or header x-webhook-secret).
BREVO_WEBHOOK_SECRET=
# BREVO_SENDER_EMAIL=notifications@yourdomain.com
# BREVO_SENDER_NAME=Foundly Start

# Mailgun (email sending & inbound reply capture)
# - MAILGUN_API_KEY: Private API key (Mailgun → Settings → API Keys)
# - MAILGUN_DOMAIN: Your Mailgun sending/receiving domain (e.g. mg.yourdomain.com)
# - MAILGUN_REGION: us | eu (defaults to "us" if not set)
# - MAILGUN_REPLY_TO: Reply-to address that is handled by a Mailgun Route and forwarded to /api/webhooks/mailgun/inbound
#   Example: replies@mg.yourdomain.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# MAILGUN_REGION=eu
# MAILGUN_REPLY_TO=replies@mg.yourdomain.com

# CORS: comma-separated list of allowed origins (e.g. https://app.example.com)
ALLOWED_ORIGINS=

# Logging (default: stdout only; no writable filesystem required)
# LOG_LEVEL=info
# LOG_PRETTY=1
# Optional: set to a file path to also write logs to file (e.g. /var/log/foundly-start/app.log)
# LOG_FILE=

# Optional – default criteria for lead scoring (1–10) when using Score in UI
# LEAD_SCORING_CRITERIA=B2B fit, UK-based, has contact info

# LinkedIn (optional – Apify actor for company data; set in Run panel when source=LinkedIn)
# APIFY_API_TOKEN=
# APIFY_LINKEDIN_ACTOR_ID=harvestapi~linkedin-company

# Deep enrichment stage timeouts (milliseconds). Defaults: find 25s, scrape 45s, linkedin 45s, validate 12s.
# ENRICHMENT_WEBSITE_FIND_MS=25000
# ENRICHMENT_WEBSITE_SCRAPE_MS=45000
# ENRICHMENT_LINKEDIN_MS=45000
# ENRICHMENT_VALIDATE_MS=12000

# CRM push (optional – set in Profile for Push to HubSpot/Pipedrive/Salesforce)
# HUBSPOT_API_KEY=
# PIPEDRIVE_API_TOKEN=
# PIPEDRIVE_DOMAIN=
# SALESFORCE_ACCESS_TOKEN=
# SALESFORCE_INSTANCE_URL=

# Team members for Assign lead (optional – comma-separated; or set in Profile)
# TEAM_MEMBERS=Alice, Bob, Carol

# Scheduled pipeline (optional – cron expression and source)
# CRON_SCHEDULE=
# SCHEDULED_RUN_SOURCE=companies_house
# SCHEDULED_RUN_LIMIT=20
