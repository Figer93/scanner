{
    "name": "foundly-start",
    "version": "1.0.0",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "concurrently \"node src/server.js\" \"cd ui && npm run dev\"",
        "build": "cd ui && npm run build && node ../scripts/copy-ui-dist.js",
        "export:html": "cd ui && npm run build:single && node ../scripts/copy-export-html.js",
        "sync:companies-house": "node scripts/sync-companies-house.js",
        "lint": "npx eslint src scripts",
        "lint:ui": "cd ui && npm run lint",
        "lint:all": "npm run lint && npm run lint:ui"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "axios": "^1.13.6",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "multer": "^2.1.1",
        "node-cron": "^3.0.3",
        "pg": "^8.13.1",
        "pino": "^10.3.1",
        "playwright": "^1.58.2",
        "socket.io": "^4.8.3",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.15.0",
        "pino-pretty": "^13.1.3",
        "typescript": "^5.9.3"
    }
}
